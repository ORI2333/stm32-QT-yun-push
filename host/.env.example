HUAWEI_BACKEND_MODE=local_relay

# Huawei device-side MQTT(S) (recommended)
HUAWEI_DEVICE_NAME=your_device_id
HUAWEI_DEVICE_SECRET=your_device_secret
HUAWEI_SERVICE_ID=env_monitor
HUAWEI_MQTT_HOST=your-instance.st1.iotda-device.cn-east-3.myhuaweicloud.com
HUAWEI_MQTT_PORT=8883
HUAWEI_MQTT_TLS=1
HUAWEI_MQTT_SIGN_TYPE=1

# Optional: explicit credentials. Leave empty to auto-sign from DEVICE_NAME/DEVICE_SECRET.
HUAWEI_MQTT_USERNAME=
HUAWEI_MQTT_PASSWORD=
HUAWEI_MQTT_CLIENT_ID=

# Optional compatibility fields
HUAWEI_PRODUCT_KEY=
HUAWEI_REGION=cn-east-3

# Huawei AMQP cloud pull (set HUAWEI_BACKEND_MODE=amqp when enabled)
HUAWEI_CONSUMER_GROUP_ID=DefaultQueue
HUAWEI_ACCESS_KEY_ID=
HUAWEI_ACCESS_KEY_SECRET=
HUAWEI_AMQP_ENDPOINT=
HUAWEI_AMQP_INSTANCE_ID=

# local relay from qt.py -> web_dashboard.py
LOCAL_RELAY_ENABLE=1
LOCAL_RELAY_HOST=127.0.0.1
LOCAL_RELAY_PORT=19091

# web listen
WEB_HOST=0.0.0.0
WEB_PORT=8000
